# URL base de tu instancia de Immich (sin barra final)
IMMICH_URL=https://immich.com

# API key de Immich (Account Settings -> API Keys)
# Permisos de lectura necesarios: album.read, asset.read, asset.view, asset.download
IMMICH_API_KEY=

# ID del album a visualizar
ALBUM_ID=xxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxx

# Puerto local del servidor
PORT=3000
