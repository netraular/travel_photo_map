# Base URL of your Immich instance (no trailing slash)
IMMICH_URL=https://immich.raular.com

# Immich API key (Account Settings -> API Keys)
# Required read permissions: album.read, asset.read, asset.view
# Optional: asset.download (only needed to serve full-resolution originals)
IMMICH_API_KEY=

# ID of the album to display
ALBUM_ID=b0a33b73-5ac3-476d-adbf-274665f90f20

# Local server port
PORT=3000
